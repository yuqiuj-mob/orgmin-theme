# Bootstrap Org-HTML Documentation Theme
# https://github.com/yuqiuj-mob/orgmin-theme
# ----------------------------------------
# Usage: Add to your org file:
#   #+SETUPFILE: https://cdn.jsdelivr.net/gh/yuqiuj-mob/orgmin-theme@main/bootstrap-orgdoc.setup

#+OPTIONS: html-style:nil html-scripts:nil toc:t num:nil ^:nil
#+HTML_DOCTYPE: html5
#+HTML_HEAD: <meta charset="utf-8">
#+HTML_HEAD: <meta name="viewport" content="width=device-width, initial-scale=1.0">
#+HTML_HEAD: <link rel="preconnect" href="https://fonts.googleapis.com">
#+HTML_HEAD: <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
#+HTML_HEAD: <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Serif+Display&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
#+HTML_HEAD: <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
#+HTML_HEAD: <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" rel="stylesheet">
#+HTML_HEAD: <link href="https://cdn.jsdelivr.net/gh/yuqiuj-mob/orgmin-theme@main/css/orgdoc.css" rel="stylesheet">
#+HTML_HEAD: <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" defer></script>
#+HTML_HEAD: <script src="https://cdn.jsdelivr.net/gh/yuqiuj-mob/orgmin-theme@main/js/orgdoc.js" defer></script>
